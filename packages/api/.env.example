PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alashed_tracker
# or individual fields:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=alashed_tracker
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false

# Auth
JWT_SECRET=change-me-in-production-use-32-chars-min

# CORS (comma-separated for prod)
CORS_ORIGINS=http://localhost:3000
